# MongoDB Atlas
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/gbv_reports

# NextAuth
NEXTAUTH_SECRET=replace-with-random-32-char-string
NEXTAUTH_URL=http://localhost:3000

# Single admin email — ONLY this email can log in to the admin panel
ADMIN_EMAIL=admin@rights4heruganda.org

# VAPID keys for push notifications
# Generate by running: node scripts/generate-vapid-keys.js
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
